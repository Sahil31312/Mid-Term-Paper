      "feature_attributes": ["SMILES", "molecular_weight", "AlogP", "HBD", "HBA", "max_phase", "atc_code", "mechanism_of_action"]
    },
    {
      "type_id": "biological_pathway",
      "label": "Biological Pathway",
      "color": "#378ADD",
      "total_count": 2900,
      "source": ["KEGG", "Reactome"],
      "identifier_attributes": ["kegg_id", "reactome_id", "go_id"],
      "feature_attributes": ["name", "category", "gene_count", "organism", "description", "hierarchy_level"]
    },
    {
      "type_id": "phenotype",
      "label": "Phenotype",
      "color": "#D4537E",
      "total_count": 6340,
      "source": ["HPO"],
      "identifier_attributes": ["hpo_id"],
      "feature_attributes": ["label", "definition", "synonyms", "frequency", "onset_class", "parent_hpo_id"]
    },
    {
      "type_id": "genetic_variant",
      "label": "Genetic Variant",
      "color": "#639922",
      "total_count": 35000,
      "source": ["PharmGKB", "dbSNP", "ClinVar"],
      "identifier_attributes": ["rsid", "clinvar_id"],
      "feature_attributes": ["chromosome", "position", "ref_allele", "alt_allele", "MAF", "consequence", "clinvar_significance", "GWAS_trait"]
    },
    {
      "type_id": "tissue_anatomy",
      "label": "Tissue / Anatomy",
      "color": "#D85A30",
      "total_count": 1200,
      "source": ["UBERON", "GTEx", "Human Protein Atlas"],
      "identifier_attributes": ["uberon_id", "bto_id", "gtex_id"],
      "feature_attributes": ["name", "tissue_type", "organ_system", "gtex_tissue_label"]
    },
    {
      "type_id": "side_effect",
      "label": "Side Effect",
      "color": "#888780",
      "total_count": 4180,
      "source": ["SIDER", "MedDRA", "FAERS"],
      "identifier_attributes": ["meddra_id", "sider_id"],
      "feature_attributes": ["label", "SOC_class", "frequency_label", "severity", "is_serious"]
    }
  ],

