{
  "metadata": {
    "name": "BioKG-Alt",
    "full_name": "Alternative Biomedical Informatics Knowledge Graph",
    "version": "1.0.0",
    "description": "An alternative to PrimeKG using LLM-Augmented Semantic Knowledge Graph (LASKG) method. Integrates 8 open-access biomedical repositories to describe diseases, genes, drugs, pathways, phenotypes, variants, tissues and side effects.",
    "method": "LLM-Augmented Semantic Knowledge Graph (LASKG)",
    "created_date": "2026-04-13",
    "instructor": "Dr. Muhammad Ishaq",
    "course": "Biomedical Informatics",
    "assessment": "Mid-Term Take-Home Exam",
    "reference_paper": "https://www.nature.com/articles/s41597-023-01960-3",
    "reference_github": "https://github.com/mims-harvard/PrimeKG",
    "statistics": {
      "total_nodes": 90120,
      "total_edges": 1173400,
      "node_types": 8,
      "relationship_types": 18,
      "data_sources": 8
    }
  },

  "data_sources": [
    {
      "id": "src_001",
      "name": "UniProt / Swiss-Prot",
      "url": "https://www.uniprot.org/sparql",
      "access_method": "SPARQL endpoint",
      "biological_scale": "Molecular",
      "provides_node_types": ["gene_protein"],
      "description": "Curated protein sequences, functions, GO terms, pathways"
    },
    {
      "id": "src_002",
      "name": "ChEMBL",
      "url": "https://www.ebi.ac.uk/chembl",
      "access_method": "REST API + SPARQL",
      "biological_scale": "Molecular",
      "provides_node_types": ["drug_compound"],
      "description": "2.4M drug-like molecules, bioactivity, ADMET properties, clinical trial phases"
    },
    {
      "id": "src_003",
      "name": "OMIM",
      "url": "https://omim.org",
      "access_method": "API download",
      "biological_scale": "Genetic / Disease",
      "provides_node_types": ["disease"],
      "description": "Genetic basis of inherited diseases, gene-phenotype mapping"
    },
    {
      "id": "src_004",
      "name": "Human Phenotype Ontology (HPO)",
      "url": "https://hpo.jax.org",
      "access_method": "OWL file + API",
      "biological_scale": "Phenotype",
      "provides_node_types": ["phenotype"],
      "description": "17,000+ standardized clinical phenotype terms with hierarchy"
    },
    {
      "id": "src_005",
      "name": "PharmGKB",
      "url": "https://www.pharmgkb.org",
      "access_method": "TSV download",
      "biological_scale": "Pharmacogenomics",
      "provides_node_types": ["genetic_variant", "drug_compound"],
      "description": "Genetic variant effects on drug response, variant-drug-disease triples"
    },
    {
      "id": "src_006",
      "name": "KEGG Pathways",
      "url": "https://www.kegg.jp",
      "access_method": "REST API",
      "biological_scale": "Pathway / Systems",
      "provides_node_types": ["biological_pathway"],
      "description": "Biological pathways, metabolic networks, disease pathway maps"
    },
    {
      "id": "src_007",
      "name": "BioGRID",
      "url": "https://thebiogrid.org",
      "access_method": "Tab file download",
      "biological_scale": "Interaction",
      "provides_node_types": ["gene_protein"],
      "description": "2.4M+ curated protein-protein and genetic interactions"
    },
    {
      "id": "src_008",
      "name": "ClinicalTrials.gov",
      "url": "https://clinicaltrials.gov/api",
      "access_method": "REST API (JSON)",
      "biological_scale": "Clinical",
      "provides_node_types": ["disease", "drug_compound"],
      "description": "Clinical trial conditions, interventions, outcomes, eligibility criteria"
    }
  ],

  "node_types": [
    {
      "type_id": "disease",
      "label": "Disease",
      "color": "#1D9E75",
      "total_count": 12540,
      "source": ["OMIM", "Disease Ontology", "MONDO"],
      "identifier_attributes": ["do_id", "icd10_code", "omim_id", "mondo_id", "orphanet_id", "mesh_id"],
      "feature_attributes": ["name", "definition", "synonyms", "prevalence", "is_rare", "inheritance_mode", "clinical_description"]
    },
    {
      "type_id": "gene_protein",
      "label": "Gene / Protein",
      "color": "#7F77DD",
      "total_count": 19200,
      "source": ["UniProt", "HGNC", "Ensembl"],
      "identifier_attributes": ["hgnc_id", "symbol", "uniprot_id", "ensembl_id", "ncbi_gene_id"],
      "feature_attributes": ["full_name", "chromosome", "band", "go_terms", "pfam_domains", "expression_profile", "essentiality_score"]
    },
    {
      "type_id": "drug_compound",
      "label": "Drug / Compound",
      "color": "#EF9F27",
      "total_count": 8760,
      "source": ["ChEMBL", "DrugBank", "PubChem"],
